      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-01-01",
      "name": "[format('nsg-bastion-{0}', variables('prefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
