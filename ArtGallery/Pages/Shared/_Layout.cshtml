<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArtGallery</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <a class="brand" href="/">Mitt galleri</a>
        <nav>
            <a href="/">Galleri</a>
            <a href="/Upload">Ladda upp</a>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        <p>&copy; @DateTime.Now.Year - Mitt galleri</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
